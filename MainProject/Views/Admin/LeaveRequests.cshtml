@model IEnumerable<Domain.LeaveRequestViewModel>

<h2>Leave Requests</h2>

<a asp-controller="Admin" asp-action="Dashboard" class="btn btn-secondary">
    Back to Dashboard
</a>

<br>
<br>
<table border="1" cellpadding="8">

    <tr>
        <th>Employee</th>
        <th>From</th>
        <th>To</th>
        <th>Reason</th>
        <th>Status</th>
        <th>Action</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.EmployeeName</td>
            <td>@item.FromDate</td>
            <td>@item.ToDate</td>
            <td>@item.Reason</td>
            <td>@item.Status</td>

            <td>
                <a asp-action="ApproveLeave" asp-route-id="@item.Id">Approve</a> |
                <a asp-action="RejectLeave" asp-route-id="@item.Id">Reject</a>
            </td>
        </tr>
    }

</table>