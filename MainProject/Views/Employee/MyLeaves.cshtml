@model IEnumerable<Domain.LeaveRequestViewModel>

<h2>My Leaves</h2>

<table border="1" cellpadding="8">

    <tr>
        <th>From Date</th>
        <th>To Date</th>
        <th>Reason</th>
        <th>Status</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.FromDate</td>
            <td>@item.ToDate</td>
            <td>@item.Reason</td>
            <td>@item.Status</td>
        </tr>
    }

</table>

<br>

<a asp-action="Dashboard" class="btn btn-secondary">
    Back to Dashboard
</a>